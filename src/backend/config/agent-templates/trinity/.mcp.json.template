{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "trinity": {
      "type": "http",
      "url": "${TRINITY_URL}/mcp",
      "headers": {
        "Authorization": "Bearer ${TRINITY_API_KEY}"
      }
    }
  }
}
